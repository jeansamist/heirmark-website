# Public site URL used for Stripe success/cancel URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (optional for local testing; when omitted checkout redirects directly to /payment-success).
STRIPE_SECRET_KEY=
# Optional: If set, this existing Stripe Price ID is used instead of dynamic price_data.
STRIPE_COLLECTION_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# SMTP for order confirmation, contact form, and booking request emails.
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_SECURE=true,
# SMTP_USER=you@gmail.com, SMTP_PASS=<16-character App Password>.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Set true when using implicit TLS (usually port 465); otherwise false.
SMTP_SECURE=false

# Inbox that receives Contact Form and Booking Request notifications.
ADMIN_NOTIFICATION_EMAIL=info@theheirmarkframework.com
